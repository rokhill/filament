# ---- Aether Exchange frontend configuration ----

# Reown (WalletConnect) project id — free at https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Contract addresses — printed by contracts/scripts/deploy.js
NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_WLCAI_ADDRESS=

# Public site URL (must match the domain Reown is configured for)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional remote nav/footer JSON configs (leave empty to disable)
NEXT_PUBLIC_NAV_CONFIG_URL=
NEXT_PUBLIC_FOOTER_CONFIG_URL=

# Bridge (LCAI <-> Ethereum via LightChain's Hyperlane warp route)
# Set to "false" to hide the Bridge tab entirely.
NEXT_PUBLIC_BRIDGE_ENABLED=true
# Optional dedicated Ethereum RPC (Alchemy/Infura). Defaults to a public RPC.
NEXT_PUBLIC_ETH_RPC_URL=
